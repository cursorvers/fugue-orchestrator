{
  "preferred_org_secrets": [
    "OPENAI_API_KEY",
    "ZAI_API_KEY",
    "XAI_API_KEY",
    "DISCORD_ADMIN_WEBHOOK_URL",
    "DISCORD_WEBHOOK_URL",
    "N8N_API_KEY",
    "SUPABASE_ACCESS_TOKEN",
    "SUPABASE_URL",
    "GOOGLE_SERVICE_ACCOUNT_JSON",
    "PROGRESS_WEBHOOK_URL",
    "LINE_WEBHOOK_URL",
    "FUGUE_OPS_PAT"
  ],
  "optional_org_secrets": [
    "ANTHROPIC_API_KEY"
  ],
  "preferred_org_variables": [
    "SUPABASE_PROJECT_ID",
    "N8N_INSTANCE_URL"
  ],
  "allow_repo_secrets": [
    "TARGET_REPO_PAT",
    "DISCORD_SYSTEM_WEBHOOK",
    "LINE_NOTIFY_TOKEN",
    "LINE_NOTIFY_ACCESS_TOKEN",
    "LINE_CHANNEL_ACCESS_TOKEN",
    "LINE_TO"
  ],
  "repos": {
    "cursorvers/fugue-orchestrator": {
      "required": [
        "OPENAI_API_KEY",
        "ZAI_API_KEY",
        "TARGET_REPO_PAT"
      ],
      "required_any": [
        [
          "DISCORD_WEBHOOK_URL",
          "DISCORD_SYSTEM_WEBHOOK"
        ],
        [
          "LINE_WEBHOOK_URL",
          "LINE_NOTIFY_TOKEN",
          "LINE_NOTIFY_ACCESS_TOKEN",
          {
            "all_of": [
              "LINE_CHANNEL_ACCESS_TOKEN",
              "LINE_TO"
            ]
          }
        ],
        [
          "FUGUE_OPS_PAT",
          "TARGET_REPO_PAT"
        ]
      ]
    },
    "cursorvers/cloudflare-workers-hub": {
      "required": [
        "CLOUDFLARE_API_TOKEN",
        "CLOUDFLARE_ACCOUNT_ID",
        "ZAI_API_KEY",
        "XAI_API_KEY",
        "WORKERS_API_KEY",
        "WORKERS_API_URL"
      ]
    },
    "cursorvers/cursorvers_line_free_dev": {
      "required": [
        "DISCORD_ADMIN_WEBHOOK_URL",
        "SUPABASE_ACCESS_TOKEN",
        "SUPABASE_URL"
      ],
      "required_any": [
        [
          "OPENAI_API_KEY"
        ],
        [
          "TARGET_REPO_PAT"
        ]
      ]
    }
  }
}
