{
  "version": 1,
  "out_root": ".fugue/feeds/googleworkspace",
  "profiles": {
    "morning-brief": {
      "title": "Morning operator brief",
      "phase": "scheduled-operator-loop",
      "enabled_by_default": true,
      "schedule_mode": "daily-weekday",
      "recommended_cron_utc": "0 21 * * 0-4",
      "actions": [
        "standup-report",
        "gmail-triage"
      ],
      "domains": [
        "calendar",
        "gmail"
      ],
      "reason": [
        "standup-context",
        "mail-context"
      ],
      "ttl_minutes": 360,
      "auth_mode": "service-and-user-readonly",
      "summary_purpose": "Start-of-day operator digest for Kernel/FUGUE."
    },
    "pre-meeting-scan": {
      "title": "Upcoming meeting scan",
      "phase": "scheduled-operator-loop",
      "enabled_by_default": false,
      "schedule_mode": "dispatch-only",
      "recommended_cron_utc": "",
      "actions": [
        "meeting-prep"
      ],
      "domains": [
        "calendar",
        "drive",
        "docs"
      ],
      "reason": [
        "meeting-context",
        "document-context"
      ],
      "ttl_minutes": 45,
      "auth_mode": "service-or-user-readonly",
      "summary_purpose": "Short-lived next-meeting context."
    },
    "daily-mailbox-digest": {
      "title": "Daily mailbox digest",
      "phase": "scheduled-operator-loop",
      "enabled_by_default": false,
      "schedule_mode": "dispatch-only",
      "recommended_cron_utc": "",
      "actions": [
        "gmail-triage"
      ],
      "domains": [
        "gmail"
      ],
      "reason": [
        "mail-context"
      ],
      "ttl_minutes": 180,
      "auth_mode": "user-oauth-readonly",
      "summary_purpose": "Read-only unread mailbox summary."
    },
    "weekly-digest": {
      "title": "Weekly workspace digest",
      "phase": "scheduled-operator-loop",
      "enabled_by_default": true,
      "schedule_mode": "weekly",
      "recommended_cron_utc": "15 21 * * 0",
      "actions": [
        "weekly-digest"
      ],
      "domains": [
        "calendar",
        "gmail"
      ],
      "reason": [
        "digest-context"
      ],
      "ttl_minutes": 10080,
      "auth_mode": "user-oauth-readonly",
      "summary_purpose": "Weekly operator digest."
    }
  }
}
